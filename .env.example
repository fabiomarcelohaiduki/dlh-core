# =====================================================================
# DLH Core - .env.example (SPEC secao 5.3)
# Referencia de variaveis de ambiente. NUNCA commitar valores reais.
# Segredos de producao ficam no Supabase Vault, nunca neste arquivo.
# =====================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>           # apenas server-side / Edge Functions
SUPABASE_PROJECT_REF=<project-ref>

# NOTA (Edge Functions): em runtime, o Supabase injeta automaticamente
#   SUPABASE_URL, SUPABASE_ANON_KEY e SUPABASE_SERVICE_ROLE_KEY.
# Os helpers em _shared/env.ts aceitam ambos os nomes (com fallback para os
# NEXT_PUBLIC_* usados pelo front), facilitando dev local com `supabase functions serve`.

# Google OAuth (configurado no Supabase Auth)
GOOGLE_OAUTH_CLIENT_ID=<client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<client-secret>
AUTH_REDIRECT_URL=https://<app-domain>/auth/callback

# Allowlist (semente; gestao tambem via Administracao/contas_autorizadas)
AUTHORIZED_EMAIL_DOMAIN=<dominio-confiavel>

# Conector Effecti (segredo real fica no Supabase Vault; aqui apenas base)
EFFECTI_API_BASE_URL=https://<effecti-api-base>
# EFFECTI_API_TOKEN -> NAO usar .env em producao; armazenar no Supabase Vault (RNF-02)

# Embeddings (provider plugavel; default bge-m3 local, vector(1024) - delta-005)
EMBEDDINGS_PROVIDER=bge-m3-local
EMBEDDINGS_ENDPOINT=http://<embeddings-service>:<port>
EMBEDDINGS_DIM=1024

# Extracao de texto/OCR de arquivos de edital (servico self-hosted plugavel)
FILE_EXTRACTION_ENDPOINT=http://<extraction-service>:<port>
# Bucket privado do Storage onde os binarios de edital sao preservados (RF-33)
EDITAIS_BUCKET=editais

# Token de servico da Lia (API/MCP /v1; guardar/rotacionar no Vault)
LIA_SERVICE_API_KEY=<bearer-token-read-only>

# Observabilidade
SENTRY_DSN=<sentry-dsn>

# Notificacao transacional (falha de healthcheck - US-15/RF-41)
EMAIL_PROVIDER_API_KEY=<resend-or-smtp-key>
ALERT_EMAIL_RECIPIENTS=<email1>,<email2>
ALERT_EMAIL_FROM=DLH Core <alertas@<app-domain>>

# App
NEXT_PUBLIC_APP_URL=https://<app-domain>

# owner/repo do GitHub onde rodam os workflows de coleta (default: fabiomarcelohaiduki/dlh-core)
GITHUB_REPO=<owner>/<repo>
